@PACKAGE_INIT@



## refer https://stackoverflow.com/questions/60458214/install-target-dependencies-with-cmake

include(CMakeFindDependencyMacro)

if(DATELIB)
    # conditional to find_dependency here, only if date is used
    find_dependency(date REQUIRED)
endif()

include(${CMAKE_CURRENT_LIST_DIR}/@targets_export_name@.cmake)   # targets_export_name : donot change case
check_required_components("@PROJECT_NAME@")

